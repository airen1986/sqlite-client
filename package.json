{
  "name": "scl-sql",
  "version": "1.0.0",
  "description": "Browser-based SQLite client with OPFS persistence",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup": "node scripts/copy-sqlite-wasm.js",
    "postinstall": "node scripts/copy-sqlite-wasm.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{html,js,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{html,js,scss,json}\""
  },
  "keywords": ["sqlite", "wasm", "opfs", "sql-client"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "sass": "^1.69.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "bootstrap": "^5.3.8",
    "sweetalert2": "^11.26.10"
  }
}
